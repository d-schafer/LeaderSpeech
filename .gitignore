# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Secrets (read from local files, never committed) ---
openai_key.txt
*.key
.env

# --- Scraped + working data (shared via Zenodo/Dataverse, not git) ---
data/scraped/
data/state/
data/cleaned/
data/clean_state/
data/_build/
data/audio_video/
_data_outside_unorganized/

# --- Raw source sub-lists: the curated master list IS committed (researcher-owned); its raw inputs are not ---
data/sources/*.txt
data/sources/*.csv
data/sources/LeadersSpeeches_Africa.xlsx
# agent outbox: committed. One file per source under additional_master_sources/
# (see that folder's README + .gitattributes); the legacy flat file is kept frozen.
# The non-recursive data/sources/*.csv rule above does not match the subfolder, but
# keep an explicit allow so a future recursive rule can't hide the fragments.
!data/sources/master_sources.xlsx
!data/sources/additional_master_sources.csv
!data/sources/additional_master_sources/

# --- Large / binary data artifacts ---
*.RData
*.rdata
*.feather
*.parquet

# --- R / RStudio ---
.Rproj.user/
.Rhistory
.RData

# --- OS / editor ---
.DS_Store
Thumbs.db
