# .xlsx it replaced forced a manual conflict resolution on every concurrent PR.
# Agents MUST append their row (never rewrite the file) for union merges to stay clean.
# See docs/agent_task_end_to_end.md.
data/sources/additional_master_sources.csv text eol=lf merge=union
